  "domain": {
    "code": "RE-BROKERAGE",
    "name": "Real Estate Brokerage and Agent Operations",
    "description": "Lead capture, transaction management (offer→close), MLS syndication, commission splits, tour scheduling, and broker CRM for residential and commercial brokerages. Buyer is the brokerage / individual agent (per-seat pricing) or the franchise (enterprise pricing). Distinct from generic CRM (deal model is the property transaction, not the sales opportunity; commissions are split across cooperating brokerages by MLS rules).",
    "parent_domain_code": null,
    "certification_required": false,
    "catalog_tagline": "Run the brokerage from first lead to closed deal.",
    "catalog_description": "Capture and nurture buyer and seller leads, publish listings to the MLS, schedule and track tours, and move every offer through escrow, contingencies, and closing. Calculate cooperating-broker and internal agent commission splits, keep state-mandated disclosures complete for compliance, and hand the closed transaction off to property management and accounting. Built for the way agents and brokers actually work a deal, not a generic sales pipeline."
  },
