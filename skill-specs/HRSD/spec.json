  "domain": {
    "code": "HRSD",
    "name": "HR Service Delivery",
    "description": "Employee case management, knowledge, journeys, and document management for the HR function.",
    "parent_domain_code": null,
    "certification_required": false,
    "catalog_tagline": "Give employees one place to ask HR questions, get answers, and track every request to resolution.",
    "catalog_description": "Run employee HR support as a single service experience. Employees raise questions and requests from a self-service portal, find answers in a curated knowledge base, and watch their case move from intake to resolution without chasing anyone.\n\nBehind the scenes, incoming cases are triaged and routed to the right HR specialist, escalated across payroll, benefits, access, and other teams when needed, and resolved against documented service levels. Approvals, assignments, and reopen handling are built into the workflow so nothing slips between stages.\n\nAs cases resolve, the knowledge base grows from real questions, deflecting future requests and freeing HR teams to focus on the cases that genuinely need a human."
  },
