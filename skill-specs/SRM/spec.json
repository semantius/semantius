  "domain": {
    "code": "SRM",
    "name": "Supplier Relationship Management",
    "description": "Supplier onboarding, master data, performance, and relationship management.",
    "parent_domain_code": null,
    "certification_required": false,
    "catalog_tagline": "Onboard new suppliers, qualify them against your standards, and monitor performance and risk on one supplier record.",
    "catalog_description": "Run supplier onboarding from invite through KYC, banking, tax, and sanctions checks. Capture insurance, ISO, and SOC certifications with automatic expiry alerts so renewals never lapse.\n\nScore supplier performance against delivery, quality, and SLA targets. Roll KPIs into tiered scorecards your category managers and finance teams share.\n\nAssess supplier risk on financial, ESG, cyber, and operational axes. Escalate elevated scores to governance and procurement for re-qualification or replacement."
  },
