---
// Domain landing page body, rendered at /blueprints/<domain-code-lower>.
// First iteration: the domain's data (code, name, description) plus its
// modules in a 2-column grid.
import Layout from '~/layouts/Layout.astro';
import ModuleCard from '~/components/blueprints/ModuleCard.astro';

interface ModuleData {
	code: string;
	name: string;
	description: string;
	catalog_description?: string;
}
interface DomainData {
	code: string;
	name: string;
	description: string;
	catalog_description?: string;
	modules: ModuleData[];
}
interface Props {
	domain: DomainData;
}
const { domain } = Astro.props;
// Prefer the buyer-facing catalog copy; fall back to the technical description.
const description = domain.catalog_description ?? domain.description;
---

<Layout title={domain.name} description={description}>
	<section class="pt-32 pb-16">
		<div class="max-w-5xl mx-auto px-6">
			<div class="mb-6">
				<a href="/blueprints" class="text-sm text-muted-foreground hover:text-primary">
					&larr; Blueprints
				</a>
			</div>

			<span class="inline-block rounded-full bg-primary/10 px-3 py-1 text-xs font-semibold uppercase tracking-wide text-primary">
				{domain.code}
			</span>
			<h1 class="mt-3 text-3xl font-display font-bold lg:text-4xl">{domain.name}</h1>
			<p class="mt-4 max-w-3xl text-foreground/80">{description}</p>

			{domain.modules.length > 0 && (
				<div class="mt-10 grid grid-cols-1 gap-6 md:grid-cols-2">
					{domain.modules.map((module) => (
						<ModuleCard module={module} headingTag="h2" />
					))}
				</div>
			)}
		</div>
	</section>
</Layout>
