---
export const prerender = true;
import { type CollectionEntry, getCollection } from 'astro:content';
import Layout from '~/layouts/Layout.astro';
import { renderSubsetHtml } from '~/lib/models-extract';

export async function getStaticPaths() {
	const skills = await getCollection('skills');
	// Entry IDs are "<folder>/README" so the slug is the folder name.
	return skills.map((skill) => ({
		params: { slug: skill.id.split('/')[0] },
		props: { skill },
	}));
}

interface Props {
	skill: CollectionEntry<'skills'>;
}

const { skill } = Astro.props;
// Entry ID is "<folder>/README" so the slug is the folder name.
const slug = skill.id.split('/')[0];
// Render the raw SKILL.md body stored in the merged collection data.
const skillHtml = skill.data.skillBody ? renderSubsetHtml(skill.data.skillBody) : '';
---

<Layout
	title={`${skill.data.title} - Skill`}
	description={skill.data.description || `Agent skill: ${skill.data.title}.`}
	noindex={skill.data.noindex}
	nofollow={skill.data.nofollow}
>
	<section class="pt-32 pb-16">
		<div class="max-w-3xl mx-auto px-6">
			<div class="mb-6 flex items-center justify-between gap-3">
				<a
					href={`/skills/${slug}`}
					class="text-sm text-muted-foreground hover:text-primary"
				>
					&larr; {skill.data.title}
				</a>
			</div>

			<div class="mb-6 rounded-lg border border-border bg-muted/40 p-4 text-sm">
				<dl class="grid grid-cols-[auto_1fr] gap-x-4 gap-y-1">
					{skill.data.name && (
						<>
							<dt class="font-semibold text-muted-foreground">Name</dt>
							<dd>{skill.data.name}</dd>
						</>
					)}
					{skill.data.semantic_model && (
						<>
							<dt class="font-semibold text-muted-foreground">Model</dt>
							<dd>
								<a href={`/models/${skill.data.semantic_model}`} class="text-primary hover:underline">
									{skill.data.semantic_model}
								</a>
							</dd>
						</>
					)}
					{skill.data.generated_from && (
						<>
							<dt class="font-semibold text-muted-foreground">Generated from</dt>
							<dd>{skill.data.generated_from}</dd>
						</>
					)}
				</dl>
			</div>

			<div class="prose dark:prose-invert prose-base max-w-none prose-headings:font-display prose-headings:font-bold prose-headings:text-foreground prose-a:text-primary hover:prose-a:text-primary/80 prose-img:rounded-xl prose-code:before:content-none prose-code:after:content-none">
				{skillHtml ? (
					<div set:html={skillHtml} />
				) : (
					<p class="text-muted-foreground">No skill specification available.</p>
				)}
			</div>
		</div>
	</section>
</Layout>
