---
export const prerender = true;
import { type CollectionEntry, getCollection, render } from 'astro:content';
import Layout from '~/layouts/Layout.astro';
import Command from '~/components/common/Command.astro';

export async function getStaticPaths() {
	const skills = await getCollection('skills');
	// Entry IDs are "<folder>/README" so the slug is the folder name.
	return skills.map((skill) => ({
		params: { slug: skill.id.split('/')[0] },
		props: { skill },
	}));
}

interface Props {
	skill: CollectionEntry<'skills'>;
}

const { skill } = Astro.props;
// Entry ID is "<folder>/README" so the slug is the folder name.
const slug = skill.id.split('/')[0];
const { Content } = await render(skill);

// Look up the related model to get its display name.
let relatedModel: CollectionEntry<'models'> | undefined;
if (skill.data.semantic_model) {
	const allModels = await getCollection('models');
	relatedModel = allModels.find((m) => m.data.system_slug === skill.data.semantic_model);
}
---

<Layout
	title={skill.data.title}
	description={skill.data.description || `Agent skill: ${skill.data.title}.`}
	noindex={skill.data.noindex}
	nofollow={skill.data.nofollow}
>
	<section class="pt-32 pb-16">
		<div class="max-w-3xl mx-auto px-6">
			<div class="mb-6 flex items-center justify-between gap-3">
				<a href="/skills" class="text-sm text-muted-foreground hover:text-primary">
					&larr; Skills
				</a>
				<a
					href={`/skills/${slug}/skill`}
					class="inline-flex items-center gap-1.5 rounded-full border border-primary px-3 py-1.5 text-xs font-semibold text-foreground transition hover:bg-primary hover:text-white"
				>
					<svg xmlns="http://www.w3.org/2000/svg" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" class="h-3.5 w-3.5">
						<path d="M2 12s3-7 10-7 10 7 10 7-3 7-10 7-10-7-10-7Z" />
						<circle cx="12" cy="12" r="3" />
					</svg>
					View Skill
				</a>
			</div>

			<div class="not-prose mb-8">
				<Command command={`npx skills add https://github.com/semantius/semantius/tree/main/skills/${slug}`} />
			</div>

			<div class="prose dark:prose-invert prose-base max-w-none prose-headings:font-display prose-headings:font-bold prose-headings:text-foreground prose-a:text-primary hover:prose-a:text-primary/80 prose-img:rounded-xl prose-code:before:content-none prose-code:after:content-none">
				<Content />

				{skill.data.semantic_model && relatedModel && (
					<div class="not-prose mt-6">
						<a
							href={`/models/${skill.data.semantic_model}`}
							class="text-sm text-primary hover:text-primary/80 font-medium"
						>
							Learn more about the {relatedModel.data.system_name} semantic model &rarr;
						</a>
					</div>
				)}
			</div>
		</div>
	</section>
</Layout>
