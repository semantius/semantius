---
export const prerender = true;
import { getCollection } from 'astro:content';
import Layout from '~/layouts/Layout.astro';
import Command from '~/components/common/Command.astro';
import SkillInstall from '~/components/common/SkillInstall.astro';

// One skill per domain. The page is driven by the per-domain catalog copy
// (catalogs collection, from skill-specs/<CODE>/catalog.yaml), with the slug =
// domain code lowercased (e.g. /skills/ats). The domain map supplies the
// modules whose blueprints back this domain.
export async function getStaticPaths() {
	const catalogs = await getCollection('catalogs');
	const domains = await getCollection('domains');
	const modulesByCode = new Map(domains.map((d) => [d.data.code, d.data.modules]));
	return catalogs.map((catalog) => ({
		params: { slug: (catalog.data.domain_code_lower ?? catalog.data.domain_code).toLowerCase() },
		props: {
			catalog: catalog.data,
			modules: modulesByCode.get(catalog.data.domain_code) ?? [],
		},
	}));
}

const { catalog, modules } = Astro.props;

// The catalog_description block scalar holds one or more paragraphs separated
// by blank lines.
const paragraphs = (catalog.catalog_description ?? '')
	.split(/\n\s*\n/)
	.map((p) => p.trim())
	.filter(Boolean);

// Install command mirrors the one the remark plugin injects on skill READMEs.
// SkillInstall wraps this URL in `npx skills add <url> ...` and appends the
// agent/global flags chosen in its UI.
const installUrl = catalog.skill_name
	? `https://github.com/semantius/semantius/tree/main/skills/${catalog.skill_name}`
	: null;

// Usage command shows how to invoke the installed skill in chat.
const usageCommand = catalog.skill_name ? `/${catalog.skill_name} get started` : null;
---

<Layout
	title={catalog.domain_name}
	description={catalog.catalog_tagline || `Agent skill for ${catalog.domain_name}.`}
>
	<section class="pt-32 pb-16">
		<div class="max-w-3xl mx-auto px-6">
			<div class="mb-6">
				<a href="/skills" class="text-sm text-muted-foreground hover:text-primary">
					&larr; Skills
				</a>
			</div>

			<span class="inline-block rounded-full bg-primary/10 px-3 py-1 text-xs font-semibold uppercase tracking-wide text-primary">
				{catalog.domain_code}
			</span>
			<h1 class="mt-3 text-3xl font-display font-bold lg:text-4xl">{catalog.domain_name}</h1>
			{catalog.catalog_tagline && (
				<p class="mt-4 text-lg text-foreground/90">{catalog.catalog_tagline}</p>
			)}

			{paragraphs.length > 0 && (
				<div class="mt-6 space-y-4 text-foreground/80">
					{paragraphs.map((paragraph) => (
						<p>{paragraph}</p>
					))}
				</div>
			)}

			{installUrl && (
				<div class="mt-10">
					<SkillInstall url={installUrl} title={`Install the ${catalog.skill_name} skill`} />
				</div>
			)}

			{usageCommand && (
				<div class="mt-10">
					<h2 class="mb-3 text-sm font-semibold uppercase tracking-wide text-muted-foreground">
						How to use the {catalog.domain_name}
					</h2>
					<Command mode="chat" command={usageCommand} />
				</div>
			)}

			{catalog.capability_names.length > 0 && (
				<div class="mt-10">
					<h2 class="mb-3 text-sm font-semibold uppercase tracking-wide text-muted-foreground">
						What it does
					</h2>
					<div class="flex flex-wrap gap-2">
						{catalog.capability_names.map((capability) => (
							<span class="inline-flex items-center rounded-full border border-border px-3 py-1.5 text-sm text-foreground/90">
								{capability}
							</span>
						))}
					</div>
				</div>
			)}

			{modules.length > 0 && (
				<div class="mt-10 border-t border-border pt-8">
					<h2 class="mb-3 text-sm font-semibold uppercase tracking-wide text-muted-foreground">
						Related blueprints
					</h2>
					<div class="flex flex-wrap gap-2">
						{modules.map((module) => (
							<a
								href={`/blueprints/${module.code.toLowerCase()}`}
								class="inline-flex items-center gap-1.5 rounded-full border border-primary px-4 py-2 text-sm font-semibold text-foreground transition hover:bg-primary hover:text-white"
							>
								{module.name}
							</a>
						))}
					</div>
				</div>
			)}

			{catalog.skill_name && (
				<div class="mt-10 border-t border-border pt-6">
					<a
						href={`https://github.com/semantius/semantius/tree/main/skills/${catalog.skill_name}`}
						target="_blank"
						rel="noopener noreferrer"
						class="inline-flex items-center gap-2 text-sm text-muted-foreground hover:text-foreground transition-colors"
					>
						<svg xmlns="http://www.w3.org/2000/svg" viewBox="0 0 24 24" fill="currentColor" class="h-4 w-4">
							<path d="M12 0c-6.626 0-12 5.373-12 12 0 5.302 3.438 9.8 8.207 11.387.599.111.793-.261.793-.577v-2.234c-3.338.726-4.033-1.416-4.033-1.416-.546-1.387-1.333-1.756-1.333-1.756-1.089-.745.083-.729.083-.729 1.205.084 1.839 1.237 1.839 1.237 1.07 1.834 2.807 1.304 3.492.997.107-.775.418-1.305.762-1.604-2.665-.305-5.467-1.334-5.467-5.931 0-1.311.469-2.381 1.236-3.221-.124-.303-.535-1.524.117-3.176 0 0 1.008-.322 3.301 1.23.957-.266 1.983-.399 3.003-.404 1.02.005 2.047.138 3.006.404 2.291-1.552 3.297-1.23 3.297-1.23.653 1.653.242 2.874.118 3.176.77.84 1.235 1.911 1.235 3.221 0 4.609-2.807 5.624-5.479 5.921.43.372.823 1.102.823 2.222v3.293c0 .319.192.694.801.576 4.765-1.589 8.199-6.086 8.199-11.386 0-6.627-5.373-12-12-12z"/>
						</svg>
						Review skill details on GitHub
					</a>
				</div>
			)}
		</div>
	</section>
</Layout>
