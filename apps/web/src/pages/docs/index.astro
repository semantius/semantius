---
import Layout from '~/layouts/Layout.astro';
import { getCollection } from 'astro:content';
import { buildDocsTree, flattenTree } from '~/lib/docs-tree';

const docs = await getCollection('docs');
const tree = buildDocsTree(docs);
const flat = flattenTree(tree);
const first = flat[0];

if (first) {
    return Astro.redirect(first.path);
}
---

<Layout title="Documentation" noindex={true} nofollow={true}>
    <div class="max-w-7xl mx-auto px-6 pt-32 pb-24 text-center">
        <h1 class="text-4xl font-bold mb-4 text-foreground">Documentation</h1>
        <p class="text-xl text-foreground/70 mb-8">No documentation found.</p>
        <a href="/" class="text-primary hover:text-primary/80 transition-colors">Go back home</a>
    </div>
</Layout>
