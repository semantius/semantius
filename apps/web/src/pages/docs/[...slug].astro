---
export const prerender = true;
import { type CollectionEntry, getCollection, render } from 'astro:content';
import DocsLayout from '~/layouts/DocsLayout.astro';

export async function getStaticPaths() {
	const docs = await getCollection('docs');
	// Routes mirror the on-disk folder structure under content/docs.
	// A folder's `index.mdx` becomes the bare folder URL (e.g. models/index.mdx → /docs/models).
	return docs.map((doc) => {
		const fullSlug = doc.id.replace(/\.[^/.]+$/, "");
		const routeSlug = fullSlug.replace(/(^|\/)index$/, '');
		return {
			params: { slug: routeSlug || undefined },
			props: doc,
		};
	});
}
type Props = CollectionEntry<'docs'>;

const entry = Astro.props;
const { Content, headings } = await render(entry);
---

<DocsLayout
  title={entry.data.title}
  description={entry.data.description}
  noindex={entry.data.noindex}
  nofollow={entry.data.nofollow}
  headings={headings}
>
    <Content />
</DocsLayout>
