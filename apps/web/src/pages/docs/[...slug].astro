---
export const prerender = true;
import { type CollectionEntry, getCollection, render } from 'astro:content';
import DocsLayout from '~/layouts/DocsLayout.astro';

export async function getStaticPaths() {
	const docs = await getCollection('docs');
	// Routes are flat: content/docs/<any/path>/foo.mdx → /docs/foo.
	// This decouples URLs from on-disk folder structure so files can be reorganized
	// without breaking deep links. Filenames must therefore be unique across folders.
	const seen = new Map<string, string>();
	return docs.map((doc) => {
		const fullSlug = doc.id.replace(/\.[^/.]+$/, "");
		const flatSlug = fullSlug.split('/').pop()!;
		const previous = seen.get(flatSlug);
		if (previous) {
			throw new Error(
				`Docs route collision on "/docs/${flatSlug}": both "${previous}" and "${doc.id}" resolve here. Rename one of the files.`
			);
		}
		seen.set(flatSlug, doc.id);
		return {
			params: { slug: flatSlug },
			props: doc,
		};
	});
}
type Props = CollectionEntry<'docs'>;

const entry = Astro.props;
const { Content, headings } = await render(entry);
---

<DocsLayout
  title={entry.data.title}
  description={entry.data.description}
  noindex={entry.data.noindex}
  nofollow={entry.data.nofollow}
  headings={headings}
>
    <Content />
</DocsLayout>
