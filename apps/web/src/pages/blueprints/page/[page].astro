---
export const prerender = true;
import { getCollection } from 'astro:content';

// The blueprints listing is now a single domain-grouped page at /blueprints
// (see ../index.astro). These /blueprints/page/N URLs used to paginate the
// per-module blueprint grid (4 per page). They are kept only as redirects so
// previously indexed URLs and external links collapse to the new single page
// instead of 404ing. The page set mirrors the old last page (blueprint count
// divided by the old page size of 4), starting at 2 because page 1 was
// /blueprints itself.
export async function getStaticPaths() {
	const count = (await getCollection('blueprints')).length;
	const oldLastPage = Math.max(1, Math.ceil(count / 4));
	const paths = [];
	for (let p = 2; p <= oldLastPage; p++) {
		paths.push({ params: { page: String(p) } });
	}
	return paths;
}
---

<!doctype html>
<html lang="en">
	<head>
		<meta charset="utf-8" />
		<meta http-equiv="refresh" content="0; url=/blueprints" />
		<link rel="canonical" href="/blueprints" />
		<meta name="robots" content="noindex" />
		<title>Semantic Blueprints</title>
	</head>
	<body>
		<p>This page has moved to <a href="/blueprints">/blueprints</a>.</p>
	</body>
</html>
