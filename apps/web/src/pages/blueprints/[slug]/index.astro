---
export const prerender = true;
import { type CollectionEntry, getCollection } from 'astro:content';
import Layout from '~/layouts/Layout.astro';
import Command from '~/components/common/Command.astro';
import DomainLanding from '~/components/blueprints/DomainLanding.astro';

// This route serves two page kinds at /blueprints/<slug>:
//   - 'blueprint': a module's semantic blueprint detail (slug = system_slug).
//   - 'domain':    a domain landing page (slug = domain code lowercased).
// Domain landings are skipped for any domain whose code collides with a
// blueprint slug (the single-module bundle/starter domains), so the richer
// blueprint detail keeps that URL.
export async function getStaticPaths() {
	const blueprints = await getCollection('blueprints');
	const blueprintSlugs = new Set(blueprints.map((b) => b.data.system_slug));
	const domains = await getCollection('domains');

	// The buyer-facing `catalog_description` lives on the domain-map module
	// (domain-map.json), keyed by module code. A blueprint's `system_name` is that
	// same code, so we join on it to surface the catalog copy on the detail page
	// (the same copy the listing cards prefer). See content.config.ts.
	const catalogDescriptions = new Map<string, string>();
	for (const domain of domains) {
		for (const module of domain.data.modules) {
			if (module.catalog_description) {
				catalogDescriptions.set(module.code, module.catalog_description);
			}
		}
	}

	const blueprintPaths = blueprints.map((blueprint) => ({
		params: { slug: blueprint.data.system_slug },
		props: {
			kind: 'blueprint' as const,
			blueprint,
			catalogDescription: catalogDescriptions.get(blueprint.data.system_name) ?? '',
		},
	}));

	const domainPaths = domains
		.filter((domain) => !blueprintSlugs.has(domain.data.code.toLowerCase()))
		.map((domain) => ({
			params: { slug: domain.data.code.toLowerCase() },
			props: { kind: 'domain' as const, domain },
		}));

	return [...blueprintPaths, ...domainPaths];
}

type Props =
	| { kind: 'blueprint'; blueprint: CollectionEntry<'blueprints'>; catalogDescription: string }
	| { kind: 'domain'; domain: CollectionEntry<'domains'> };

const props = Astro.props as Props;

// Blueprint-only data; computed only when rendering a blueprint detail page.
let blueprint: CollectionEntry<'blueprints'> | null = null;
let description = '';
let subsetHtml = '';
let date = '';
let blueprintFileUrl = '';
let systemName = '';
let seoTitle = '';
let relatedSkills: CollectionEntry<'skills'>[] = [];

if (props.kind === 'blueprint') {
	blueprint = props.blueprint;
	// Prefer the buyer-facing catalog copy (catalog_description, joined from the
	// domain map in getStaticPaths) over the technical frontmatter `description`.
	// `overview` and `subsetHtml` are derived once at collection-build time by the
	// custom loader in content.config.ts (see lib/models-extract.ts).
	description = props.catalogDescription || blueprint.data.description || blueprint.data.overview || '';
	subsetHtml = blueprint.data.subsetHtml ?? '';
	date = blueprint.data.created_at.toLocaleDateString('en-US', {
		year: 'numeric',
		month: 'long',
		day: 'numeric',
	});
	blueprintFileUrl = new URL(`/blueprints/${blueprint.id}.md`, Astro.site ?? Astro.url).toString();
	// Prefer the human-readable system_description (e.g. "Candidate CRM") for the
	// displayed title; system_name is an uppercase code/id (e.g. "ATS-CANDIDATE-CRM").
	systemName = blueprint.data.system_description ?? blueprint.data.system_name;
	// SEO/document title pairs the model title with its code/id name, e.g.
	// "Candidate CRM — ATS-CANDIDATE-CRM". Falls back to the code alone when no
	// description is set.
	seoTitle = blueprint.data.system_description
		? `${blueprint.data.system_description} — ${blueprint.data.system_name}`
		: blueprint.data.system_name;
	// Find skills related to this blueprint (semantic_model matches system_slug).
	const allSkills = await getCollection('skills');
	relatedSkills = allSkills.filter(
		(skill) => skill.data.semantic_model === blueprint!.data.system_slug,
	);
}
---

{props.kind === 'domain' && <DomainLanding domain={props.domain.data} />}

{props.kind === 'blueprint' && blueprint && (
<Layout
	title={seoTitle}
	description={description || `Semantic data blueprint for ${blueprint.data.system_name}.`}
	noindex={blueprint.data.noindex}
	nofollow={blueprint.data.nofollow}
>
	<section class="pt-32 pb-16">
		<div class="max-w-7xl mx-auto px-6">
			<div class="mb-6 flex items-center justify-between gap-3">
				<a href="/blueprints" class="text-sm text-muted-foreground hover:text-primary">
					&larr; Blueprints
				</a>
				<div class="flex items-center gap-2">
					<a
						href={`/blueprints/${blueprint.data.system_slug}/blueprint`}
						class="inline-flex items-center gap-1.5 rounded-full border border-primary px-3 py-1.5 text-xs font-semibold text-foreground transition hover:bg-primary hover:text-white"
					>
						<svg xmlns="http://www.w3.org/2000/svg" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" class="h-3.5 w-3.5">
							<path d="M2 12s3-7 10-7 10 7 10 7-3 7-10 7-10-7-10-7Z" />
							<circle cx="12" cy="12" r="3" />
						</svg>
						View Blueprint
					</a>
					<a
						href={`/blueprints/${blueprint.id}.md`}
						download
						class="inline-flex items-center gap-1.5 rounded-full border border-primary px-3 py-1.5 text-xs font-semibold text-foreground transition hover:bg-primary hover:text-white"
					>
						<svg xmlns="http://www.w3.org/2000/svg" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" class="h-3.5 w-3.5">
							<path d="M21 15v4a2 2 0 0 1-2 2H5a2 2 0 0 1-2-2v-4" />
							<polyline points="7 10 12 15 17 10" />
							<line x1="12" y1="15" x2="12" y2="3" />
						</svg>
						Download
					</a>
				</div>
			</div>

			<div class="mb-4 flex gap-3 text-sm text-muted-foreground">
				{blueprint.data.domain_code && <span>{blueprint.data.domain_code}</span>}
				<span>{date}</span>
			</div>

			{/* Narrow reading column: only the title and prose description. */}
			<div class="prose dark:prose-invert prose-base max-w-3xl prose-headings:font-display prose-headings:font-bold prose-headings:text-foreground prose-a:text-primary hover:prose-a:text-primary/80 prose-img:rounded-xl prose-code:before:content-none prose-code:after:content-none">
				<h1>{systemName}</h1>
				{description && <p>{description}</p>}
			</div>

			{/* Full container width: command box and the entity summary table. */}
			<div class="prose dark:prose-invert prose-base max-w-none mt-4 prose-headings:font-display prose-headings:font-bold prose-headings:text-foreground prose-a:text-primary hover:prose-a:text-primary/80 prose-img:rounded-xl prose-code:before:content-none prose-code:after:content-none">
				<h3>Use the {systemName} semantic blueprint</h3>
				<Command mode="chat" command={`/semantius-admin use the architect, analyst and modeler skills to update the semantius platform with the model specified in ${blueprintFileUrl}`} />
				{subsetHtml && <div set:html={subsetHtml} />}
			</div>

			{relatedSkills.length > 0 && (
				<div class="mt-10 border-t border-border pt-8">
					<p class="text-sm font-semibold text-muted-foreground mb-3">
						{relatedSkills.length === 1 ? 'Skill' : 'Skills'}
					</p>
					<div class="flex flex-wrap gap-2">
						{relatedSkills.map((skill) => (
							<a
								href={`/skills/${skill.id.split('/')[0]}`}
								class="inline-flex items-center gap-1.5 rounded-full border border-primary px-4 py-2 text-sm font-semibold text-foreground transition hover:bg-primary hover:text-white"
							>
								<svg xmlns="http://www.w3.org/2000/svg" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" class="h-4 w-4">
									<path d="M15 3l-8.5 8.5a1.5 1.5 0 0 0 2.1 2.1L17 5.1" />
									<path d="M9 17v4h4" />
									<path d="M21 3l-3 3" />
								</svg>
								{skill.data.title}
							</a>
						))}
					</div>
				</div>
			)}
		</div>
	</section>
</Layout>
)}

{props.kind === 'blueprint' && blueprint && (
<script is:inline define:vars={{ blueprintSlug: blueprint.data.system_slug, blueprintName: blueprint.data.system_name }}>
  document.addEventListener('DOMContentLoaded', function() {
    var viewBtn = document.querySelector('a[href*="/blueprint"]');
    var downloadBtn = document.querySelector('a[download]');

    if (viewBtn) {
      viewBtn.addEventListener('click', function() {
        window.posthog?.capture('blueprint_view_clicked', { blueprint_slug: blueprintSlug, blueprint_name: blueprintName });
      });
    }

    if (downloadBtn) {
      downloadBtn.addEventListener('click', function() {
        window.posthog?.capture('blueprint_download_clicked', { blueprint_slug: blueprintSlug, blueprint_name: blueprintName });
      });
    }
  });
</script>
)}
