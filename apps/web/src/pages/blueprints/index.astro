---
export const prerender = true;
import Layout from '~/layouts/Layout.astro';
import { getCollection } from 'astro:content';
import ModuleCard from '~/components/blueprints/ModuleCard.astro';

// The blueprints listing is now grouped by domain, sourced from the domain map
// (domain-map/domain-map.json via the `domains` collection). Each domain is a
// section (code, name, description); inside it each module links to its
// blueprint at /blueprints/<module-code-lowercased>.
const domains = (await getCollection('domains')).sort(
	(a, b) => a.data.order - b.data.order,
);
---

<Layout title="Semantic Blueprints" description="Semantic data blueprints you can adopt, customize, and build on, grouped by domain.">
	<section class="pt-32 pb-16">
		<div class="max-w-6xl mx-auto px-6">
			<h1 class="text-center text-4xl font-display font-normal lg:text-[56px]">Semantic Blueprints</h1>
			<p class="mx-auto mt-6 max-w-2xl text-center text-lg text-muted-foreground">
				Browse the catalog by domain. Each domain groups the modules you can adopt, customize, and build on.
			</p>

			<div class="mt-16 space-y-20">
				{domains.map((domain) => (
					<section aria-labelledby={`domain-${domain.data.code}`}>
						<div class="border-b border-border pb-6">
							<span class="inline-block rounded-full bg-primary/10 px-3 py-1 text-xs font-semibold uppercase tracking-wide text-primary">
								{domain.data.code}
							</span>
							<h2 id={`domain-${domain.data.code}`} class="mt-3 text-2xl font-display font-semibold lg:text-3xl">
								<a href={`/blueprints/${domain.data.code.toLowerCase()}`} class="hover:text-primary transition-colors">
									{domain.data.name}
								</a>
							</h2>
							<p class="mt-3 max-w-3xl text-foreground/80">{domain.data.description}</p>
						</div>

						{domain.data.modules.length > 0 && (
							<div class="mt-8 grid grid-cols-1 gap-6 sm:grid-cols-2 lg:grid-cols-3">
								{domain.data.modules.map((module) => (
									<ModuleCard module={module} />
								))}
							</div>
						)}
					</section>
				))}
			</div>
		</div>
	</section>
</Layout>
